# --- Firebase Configuration ---
# Get these from your Firebase Console -> Project Settings
FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your_project.firebaseio.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_id
FIREBASE_APP_ID=your_app_id

# --- Admin Configuration ---
# Comma-separated list of emails that have access to /admin
ADMIN_EMAILS=your-email@example.com

# --- Composio Configuration ---
# Get these from https://app.composio.dev
COMPOSIO_API_KEY=your_composio_api_key
COMPOSIO_USER_ID=your_composio_user_id

# --- Cloudflare Worker Proxy (Optional - For Juniors) ---
# Your juniors will use these in the Admin Dashboard
# Base URL: https://your-worker.subdomain.workers.dev/v1
# API Key: POWERED_BY_DEVIPRASAD_SHETTY (Matches PROXY_PASSPHRASE in Cloudflare)

# --- Local Provider Fallback (If DB is empty) ---
# These are used if no active provider is set in the Admin Dashboard
MODEL_NAME=google/gemini-2.0-flash-exp:free
LLM_API_KEY=your_direct_api_key
BASE_URL=https://openrouter.ai/api/v1
