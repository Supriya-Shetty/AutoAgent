# --- Backend Configuration ---

# GOOGLE_API_KEY: Obtain from https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# COMPOSIO_API_KEY: Obtain from https://app.composio.ai/ (Settings -> API Keys)
COMPOSIO_API_KEY=your_composio_api_key_here

# COMPOSIO_USER_ID: Obtain from Composio Dashboard or via CLI (composio whoami)
COMPOSIO_USER_ID=your_composio_user_id_here

# --- Frontend Firebase Configuration ---
# Obtain these from your Firebase Console -> Project Settings -> General -> Your apps (Web)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id

# --- Backend Firebase Admin (Service Account) ---
# Project Settings -> Service accounts -> Generate new private key
# Use a tool like https://www.unique-projects.org/firebase-admin-sdk-config-json-to-env-variables/ to format 
FIREBASE_CLIENT_EMAIL=your_service_account_email
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_CLIENT_X509_CERT_URL=your_cert_url

# --- Admin Configuration ---
# Comma-separated list of emails that should have access to the /admin dashboard
ADMIN_EMAILS=admin@example.com,user@example.com
